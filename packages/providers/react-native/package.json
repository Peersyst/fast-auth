{
    "name": "@fast-auth-near/react-native-provider",
    "version": "1.5.1",
    "description": "React Native provider for FastAuth - Adapts react-native-auth0 to the FastAuth provider interface",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "CHANGELOG.md",
        "package.json"
    ],
    "scripts": {
        "build": "tsup",
        "clean": "rimraf .turbo dist node_modules",
        "lint": "eslint ."
    },
    "keywords": [
        "fastauth",
        "near",
        "auth0",
        "react-native",
        "authentication",
        "blockchain"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@near-js/transactions": "^2.0.2",
        "jwt-decode": "^3.1.2",
        "near-api-js": "^4.0.4",
        "react-native-auth0": "^5.0.1"
    },
    "devDependencies": {
        "@shared/core": "workspace:*",
        "@shared/eslint": "workspace:*",
        "@shared/test": "workspace:*",
        "@shared/tsconfig": "workspace:*",
        "@types/jest": "^29.5.12",
        "@types/node": "^22.15.30",
        "@types/react": "^19.0.10",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.4",
        "ts-node": "^10.9.2",
        "tsup": "^8.2.4",
        "typescript": "^5.7.3"
    },
    "peerDependencies": {
        "react": ">=16.8.0",
        "react-native": ">=0.60.0"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    }
}
