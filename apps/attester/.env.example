PRIVATE_KEY=ed25519:xxxx
ACCOUNT_ID=xxxx.near
NODE_URL=https://xxx.com
CONTRACT_ID=google-public-keys.testnet
GUARD_CONTRACT_ID=firebase.jwt.testnet

# Key provider: "kms" (default) or "google"
KEY_PROVIDER=kms

# Google provider config
# GOOGLE_CERTIFICATES_URL=https://www.googleapis.com/robot/v1/metadata/x509/securetoken@system.gserviceaccount.com

# AWS KMS provider config (required when KEY_PROVIDER=kms)
KMS_REGION=us-east-1
KMS_PREVIOUS_KEY_ID=alias/prev
KMS_CURRENT_KEY_ID=alias/current
KMS_NEXT_KEY_ID=alias/next
